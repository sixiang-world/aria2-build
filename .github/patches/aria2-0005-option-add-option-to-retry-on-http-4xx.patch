+  "\n --retry-on-403[=true|false]\n"
+  "\n"
+  "\n"
+  TEXT_RETRY_ON_406,
+  "\n --retry-on-406[=true|false]\n"
+  "\n"
+  "\n"
+  TEXT_RETRY_ON_UNKNOWN,
+  "\n --retry-on-unknown[=true|false]\n"
+  "\n"
+  "\n"
   TEXT_RETRY_WAIT,
   "\n --retry-wait=SEC\n"
   "\n"
