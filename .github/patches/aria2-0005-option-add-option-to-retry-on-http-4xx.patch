+  {PREF_RETRY_ON_406, "retry-on-406"},
+  {PREF_RETRY_ON_UNKNOWN, "retry-on-unknown"},
   //{"PREF_SHOW_PROGRESS, "show-progress"},
   {PREF_SPLIT, "split"},
   {PREF_STREAM_PIECE_LENGTH, "stream-piece-length"},
diff --git a/src/prefs.h b/src/prefs.h
index 4e01f7c..d4c0d89 100644
--- a/src/prefs.h
+++ b/src/prefs.h
@@ -124,6 +124,10 @@ enum PREF {
   PREF_RPC_LDAP_USER_FILTER,
   PREF_SAVE_CONTROL_FILE,
+  PREF_RETRY_ON_400,
+  PREF_RETRY_ON_403,
+  PREF_RETRY_ON_406,
+  PREF_RETRY_ON_UNKNOWN,
   PREF_SHOW_PROGRESS,
   PREF_SPLIT,
   PREF_STREAM_PIECE_LENGTH,
diff --git a/src/usage_text.h b/src/usage_text.h
